# PERSONAL ACCUMULATION (stays local, never distributed)

# Brain knowledge (accumulated per-user across builds)
brain/log/errors/*
brain/log/decisions/*
brain/log/fixes/*
brain/patterns/*
brain/playbooks/*
brain/log/fragment-usage.jsonl
!brain/index.md

# Error records content (real errors from real builds)
error-records/*.md
!error-records/.gitkeep

# Experiment results (real data from self-iterate runs)
experiments/**/results.tsv
experiments/**/report.md
experiments/**/final_artifact.md

# Project directories (user's actual projects)
projects-mythic/

# Project-specific files (not part of the framework)
